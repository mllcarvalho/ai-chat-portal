{
  "name": "ai-chat-portal-extension",
  "displayName": "AI Product BMAD Chat",
  "description": "Proxy local que expõe os modelos e MCPs do GitHub Copilot para o AI Product BMAD Chat",
  "version": "0.3.29",
  "publisher": "aichatportal",
  "author": "Matheus Llobregat (https://github.com/mllcarvalho)",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aiChatPortal.openInBrowser",
        "title": "AI Product BMAD Chat: Abrir no Navegador"
      },
      {
        "command": "aiChatPortal.copyUrl",
        "title": "AI Product BMAD Chat: Copiar URL do Portal"
      },
      {
        "command": "aiChatPortal.warmup",
        "title": "AI Product BMAD Chat: Autorizar uso do Copilot"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "dependencies": {
    "@aiportal/shared": "*",
    "@joplin/turndown-plugin-gfm": "^1.0.67",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "turndown": "^7.2.4",
    "undici": "^6.21.0",
    "unpdf": "^1.3.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/turndown": "^5.0.6",
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
